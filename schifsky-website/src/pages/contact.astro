---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';
const a = site.address;
const mapQ = encodeURIComponent(`${a.street}, ${a.city}, ${a.state} ${a.zip}`);

const title = 'Contact Schifsky Companies | Landscapers in Lake Elmo, MN';
const description =
  'Contact Schifsky Companies for landscape design & build in the Twin Cities. Call or request a free quote. Based in Lake Elmo, MN, serving the metro.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  url: new URL('/contact/', site.domain).href,
  telephone: site.phone,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: a.street, addressLocality: a.city,
    addressRegion: a.state, postalCode: a.zip, addressCountry: a.country,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.geo.lat, longitude: site.geo.lng },
};
---

<Base title={title} description={description} path="/contact/" jsonLd={jsonLd}>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow on-dark">Get in Touch</span>
      <h1>Contact Schifsky Companies</h1>
      <p>Tell us about your project and we&rsquo;ll reach out within one business day.</p>
    </div>
  </section>

  <section>
    <div class="wrap contact-grid">
      <!-- FORM -->
      <div class="form-card" style="box-shadow:var(--shadow-sm);">
        <form id="contactForm" novalidate>
          <h2 style="font-size:24px;margin-bottom:4px;">Request a Free Quote</h2>
          <p class="lede">No obligation — just a conversation about your space.</p>

          <div class="field">
            <label for="name">Full Name <span class="req">*</span></label>
            <input type="text" id="name" name="name" autocomplete="name" placeholder="Jane Smith" />
            <div class="err-msg">Please enter your name.</div>
          </div>
          <div class="field row2">
            <div>
              <label for="email">Email <span class="req">*</span></label>
              <input type="email" id="email" name="email" autocomplete="email" placeholder="jane@email.com" />
              <div class="err-msg">Enter a valid email.</div>
            </div>
            <div>
              <label for="phone">Phone <span class="req">*</span></label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="(651) 555-0123" />
              <div class="err-msg">Enter a valid phone number.</div>
            </div>
          </div>
          <div class="field">
            <label for="message">How can we help? <span class="req">*</span></label>
            <textarea id="message" name="message" placeholder="A few details about your project…"></textarea>
            <div class="err-msg">Please add a short message.</div>
          </div>

          <button type="submit" class="btn btn-primary btn-block btn-lg">Send Message</button>
          <p class="legal">Your message goes straight to our team. No spam, ever.</p>
        </form>
        <div class="form-success" id="formSuccess">
          <div class="check" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M5 12.5l4.5 4.5L19 7" stroke="#2f9e44" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Thank you — message sent!</h3>
          <p>We&rsquo;ll get back to you within one business day.</p>
          <a class="btn btn-dark cta-call js-call" href={site.callHref}>Prefer to talk now? Call {site.callPhone}</a>
        </div>
      </div>

      <!-- INFO + MAP -->
      <div>
        <div class="contact-info">
          <div class="info-row">
            <span class="pin" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .58 3.6 1 1 0 0 1-.24 1Z" fill="#1a191d"/></svg></span>
            <div><b>Call us</b><a class="js-call" href={site.callHref}>{site.callPhone}</a></div>
          </div>
          <div class="info-row">
            <span class="pin" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 6h18v12H3z" stroke="#1a191d" stroke-width="2"/><path d="M3 7l9 6 9-6" stroke="#1a191d" stroke-width="2"/></svg></span>
            <div><b>Email</b><a href={`mailto:${site.email}`}>{site.email}</a></div>
          </div>
          <div class="info-row">
            <span class="pin" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-4.5-7-10a7 7 0 0 1 14 0c0 5.5-7 10-7 10Z" stroke="#1a191d" stroke-width="2"/><circle cx="12" cy="11" r="2.4" stroke="#1a191d" stroke-width="2"/></svg></span>
            <div><b>Visit / Mail</b><span>{a.street}, {a.city}, {a.state} {a.zip}</span></div>
          </div>
          <div class="info-row">
            <span class="pin" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#1a191d" stroke-width="2"/><path d="M12 7v5l3 2" stroke="#1a191d" stroke-width="2" stroke-linecap="round"/></svg></span>
            <div><b>Hours</b><span>Mon–Fri, 7am–5pm</span></div>
          </div>
        </div>
        <div class="map-embed">
          <iframe title="Map to Schifsky Companies in Lake Elmo, MN" loading="lazy"
            src={`https://www.google.com/maps?q=${mapQ}&output=embed`}
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ FORM_ENDPOINT: site.formEndpoint }}>
    (function () {
      // FORM_ENDPOINT is set from site.js (formEndpoint). When blank, the form
      // validates and shows a confirmation without sending. Setting a Formspree
      // endpoint there makes it email support@schifskycompanies.com.
      var form = document.getElementById('contactForm');
      var success = document.getElementById('formSuccess');
      if (!form) return;
      function showErr(el, on) {
        el.classList.toggle('err', on);
        var m = el.parentElement.querySelector('.err-msg');
        if (m) m.style.display = on ? 'block' : 'none';
      }
      var emailOk = function (v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); };
      var phoneOk = function (v) { return v.replace(/\D/g, '').length >= 10; };
      form.querySelectorAll('input,textarea').forEach(function (el) {
        el.addEventListener('input', function () { showErr(el, false); });
      });
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var ok = true, f = form;
        if (!f.name.value.trim()) { showErr(f.name, true); ok = false; }
        if (!emailOk(f.email.value)) { showErr(f.email, true); ok = false; }
        if (!phoneOk(f.phone.value)) { showErr(f.phone, true); ok = false; }
        if (!f.message.value.trim()) { showErr(f.message, true); ok = false; }
        if (!ok) { var fe = form.querySelector('.err'); if (fe) fe.scrollIntoView({ behavior: 'smooth', block: 'center' }); return; }
        var btn = form.querySelector('button[type=submit]');
        btn.disabled = true; btn.textContent = 'Sending…';
        function done() { form.style.display = 'none'; success.style.display = 'block'; }
        if (FORM_ENDPOINT) {
          fetch(FORM_ENDPOINT, { method: 'POST', headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(new FormData(form))) }).then(done).catch(done);
        } else { setTimeout(done, 500); }
      });
    })();
  </script>
</Base>
