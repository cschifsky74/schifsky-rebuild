---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';

const title = 'Careers | Join Schifsky Companies | Twin Cities Landscaping Jobs';
const description =
  'Build your career with Schifsky Companies, a family-owned Twin Cities landscape design & build company. Growth, an innovative environment, and a team-first culture.';

const reasons = [
  { name: 'Professional Growth', text: 'Ongoing training and the chance to work on diverse, challenging projects that grow your skills and knowledge.' },
  { name: 'Innovative Environment', text: 'We use the latest technology and techniques in design and construction — you’ll be part of a team that’s always looking forward.' },
  { name: 'Team-First Culture', text: 'As a family-run business, we value collaboration, respect, and balance between your work and personal life.' },
];
---

<Base title={title} description={description} path="/careers/">
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow on-dark">Careers</span>
      <h1>Build Your Future in the Trades</h1>
      <p>
        Join a family-owned Twin Cities landscape design &amp; build company that values your growth,
        creativity, and well-being.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap prose">
      <h2>About Schifsky Companies</h2>
      <p>
        Schifsky Companies is a family-owned business with deep roots in the Twin Cities. Specializing
        in landscape design and build, excavation, sitework, and snow removal, we serve both
        residential and commercial clients. Our team is the cornerstone of our success — dedicated to
        excellence, innovation, and integrity, and proud to create memorable outdoor living
        experiences season after season.
      </p>
    </div>
  </section>

  <section class="process">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow center">Why Work With Us</span>
        <h2>What You Can Expect</h2>
      </div>
      <div class="values">
        {reasons.map((r) => (
          <div class="value reveal">
            <h3>{r.name}</h3>
            <p>{r.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="wrap prose" style="text-align:center;">
      <h2>How to Apply</h2>
      <p>
        We&rsquo;re always interested in hearing from skilled, hard-working people who want to grow
        with us. We don&rsquo;t have specific openings posted right now — to introduce yourself or ask
        about current opportunities, send your name, experience, and resume to
        <a href={`mailto:${site.email}?subject=Careers%20at%20Schifsky%20Companies`}>{site.email}</a>,
        or reach out through our contact page.
      </p>
      <p style="margin-top:22px;">
        <a class="btn btn-primary btn-lg" href="/contact/">Contact Us About Careers</a>
      </p>
    </div>
  </section>
</Base>
