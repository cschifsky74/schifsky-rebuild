---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';

const title = 'FAQ | Landscape Design & Build Questions | Schifsky Companies';
const description =
  'Answers to common questions about landscape design & build with Schifsky Companies — free consultations, 3D design, timelines, service area, and more.';

const faqs = [
  { q: 'Is the consultation really free?', a: 'Yes. Your initial consultation and site visit are completely free with no obligation — a chance for us to understand your goals, see your property, and have an honest conversation about budget and possibilities.' },
  { q: 'Will I see the design before construction begins?', a: 'Absolutely. Our designers create a custom plan with realistic 3D renderings so you can see and refine your space before any work starts — no guesswork.' },
  { q: 'Is there a design fee?', a: 'We charge a design fee because we invest significant time creating the right plan, and a project succeeds or fails in the design phase. The good news: that design fee is credited toward your installation if you move forward with Schifsky.' },
  { q: 'What size projects do you take on?', a: 'Everything from focused outdoor upgrades to complete, large-scale backyard transformations. The best first step is a quick conversation so we can understand your goals and budget.' },
  { q: 'How long does a project take?', a: 'Timelines depend on scope, materials, and permitting. After your consultation we’ll give you a realistic schedule, and your dedicated project leader keeps you updated throughout the build.' },
  { q: 'Do you offer snow removal in winter?', a: 'Yes — we provide reliable residential and commercial snow removal and de-icing across the Twin Cities all season long, plus year-round landscape maintenance.' },
  { q: 'What areas do you serve?', a: `We’re based in ${site.address.city}, MN and serve the Twin Cities metro and surrounding suburbs, from Wayzata to Woodbury. Not sure if you’re in our area? Just ask and we’ll let you know.` },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base title={title} description={description} path="/faq/" jsonLd={jsonLd}>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow on-dark">Common Questions</span>
      <h1>Frequently Asked Questions</h1>
      <p>What to know before you start your landscape project with Schifsky Companies.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="faq-wrap">
        {faqs.map((f) => (
          <details class="faq reveal">
            <summary>{f.q} <span class="pm" aria-hidden="true">+</span></summary>
            <div class="ans">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="final">
    <div class="wrap">
      <span class="eyebrow on-dark center">Still Have Questions?</span>
      <h2>We&rsquo;re Happy to Help</h2>
      <div class="hero-cta-row">
        <a class="btn btn-primary btn-lg" href="/contact/">Get in Touch</a>
        <a class="btn btn-ghost btn-lg js-call" href={site.callHref}>Call {site.callPhone}</a>
      </div>
    </div>
  </section>
</Base>
