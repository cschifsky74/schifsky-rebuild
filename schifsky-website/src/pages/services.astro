---
import Base from '../layouts/Base.astro';
import { site, services } from '../data/site.js';

const title = 'Landscaping Services in the Twin Cities | Schifsky Companies';
const description =
  'Full-service landscape design & build in the Twin Cities: 3D design, paver patios, retaining walls, pools, pergolas, drainage, outdoor living & snow removal.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Schifsky Companies Landscaping Services',
  itemListElement: services.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.title,
    url: new URL(s.href, site.domain).href,
  })),
};
---

<Base title={title} description={description} path="/services/" jsonLd={jsonLd}>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow on-dark">What We Do</span>
      <h1>Our Landscaping Services</h1>
      <p>
        For {site.yearsInBusiness}+ years, Schifsky Companies has delivered full-service landscape
        design and build across the Twin Cities — one accountable team from first sketch to final
        walkthrough.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <p class="prose" style="margin:0 auto 36px;color:var(--muted);font-size:17px;text-align:center;">
        From 3D landscape design and paver patios to pools, pergolas, drainage, and winter snow
        removal, we handle design, hardscape, planting, and construction in-house. Explore each
        service below.
      </p>
      <div class="svc-grid">
        {services.map((s) => (
          <a class="svc-card" href={s.href}>
            <h3>{s.title}</h3>
            <p>{s.blurb}</p>
            <span class="more">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="final">
    <div class="wrap">
      <span class="eyebrow on-dark center">Start Your Project</span>
      <h2>Not Sure Where to Start?</h2>
      <p>Tell us about your space and we&rsquo;ll help you plan it. Free consultations across the Twin Cities.</p>
      <div class="hero-cta-row">
        <a class="btn btn-primary btn-lg" href="/contact/">Get a Free Quote</a>
        <a class="btn btn-ghost btn-lg js-call" href={site.callHref}>Call {site.callPhone}</a>
      </div>
    </div>
  </section>
</Base>
