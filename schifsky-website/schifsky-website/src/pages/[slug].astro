---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { site } from '../data/site.js';
import { servicePages } from '../data/servicePages.js';

// Root-level pages: blog posts AND service detail pages both live at the root
// (to preserve the exact URLs the old WordPress site used). Static pages like
// /about/ win over this dynamic route automatically.
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const postPaths = posts.map((post) => ({ params: { slug: post.slug }, props: { kind: 'post', post } }));
  const servicePaths = servicePages.map((page) => ({ params: { slug: page.slug }, props: { kind: 'service', page } }));
  return [...postPaths, ...servicePaths];
}

const { kind } = Astro.props;

// ---------- BLOG POST ----------
let Content, postTitle, description, pubDate, postSlug, fmt;
if (kind === 'post') {
  const { post } = Astro.props;
  const rendered = await post.render();
  Content = rendered.Content;
  postTitle = post.data.title;
  description = post.data.description;
  pubDate = post.data.pubDate;
  postSlug = post.slug;
  fmt = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

// ---------- SERVICE PAGE ----------
const page = Astro.props.page;

const jsonLd = kind === 'post'
  ? {
      '@context': 'https://schema.org', '@type': 'BlogPosting',
      headline: postTitle, description,
      datePublished: pubDate.toISOString().split('T')[0],
      author: { '@type': 'Organization', name: site.name },
      publisher: { '@type': 'Organization', name: site.name },
      mainEntityOfPage: new URL(`/${postSlug}/`, site.domain).href,
    }
  : {
      '@context': 'https://schema.org', '@type': 'Service',
      name: page.h1, description: page.description,
      serviceType: page.eyebrow,
      areaServed: site.serviceArea.map((c) => ({ '@type': 'City', name: c })),
      provider: {
        '@type': 'LocalBusiness', name: site.name, telephone: site.phone,
        address: {
          '@type': 'PostalAddress', streetAddress: site.address.street,
          addressLocality: site.address.city, addressRegion: site.address.state,
          postalCode: site.address.zip, addressCountry: site.address.country,
        },
      },
    };

const title = kind === 'post' ? `${postTitle} | Schifsky Companies` : page.title;
const desc = kind === 'post' ? description : page.description;
const path = kind === 'post' ? `/${postSlug}/` : `/${page.slug}/`;
---

<Base title={title} description={desc} path={path} jsonLd={jsonLd}>
  {kind === 'post' && (
    <>
      <section class="page-hero">
        <div class="wrap" style="max-width:820px;">
          <span class="eyebrow on-dark">{fmt}</span>
          <h1>{postTitle}</h1>
        </div>
      </section>
      <section>
        <article class="wrap prose">
          <Content />
          <p style="margin-top:34px;border-top:1px solid var(--line);padding-top:24px;">
            <a class="btn btn-dark" href="/blog/">&larr; Back to the blog</a>
            <a class="btn btn-primary" href="/contact/" style="margin-left:10px;">Get a Free Quote</a>
          </p>
        </article>
      </section>
    </>
  )}

  {kind === 'service' && (
    <>
      <section class="page-hero">
        <div class="wrap">
          <span class="eyebrow on-dark">{page.eyebrow}</span>
          <h1>{page.h1}</h1>
          <p>{page.lead}</p>
        </div>
      </section>

      <section>
        <div class="wrap split">
          <div class="split-img reveal">
            <img src={page.image} alt={`${page.h1} by Schifsky Companies in the Twin Cities`} width="1100" height="733" />
          </div>
          <div class="reveal prose" style="margin:0;">
            {page.body.map((p) => <p>{p}</p>)}
            {page.financing && (
              <p class="financing-note">
                <strong>Financing available.</strong> We partner with Lyon Financial for low,
                fixed-rate home-improvement loans — no equity or appraisals required.
              </p>
            )}
          </div>
        </div>
      </section>

      <section class="process">
        <div class="wrap">
          <div class="sec-head reveal">
            <span class="eyebrow center">{page.eyebrow}</span>
            <h2>{page.featureHeading}</h2>
          </div>
          <ul class="check-list" style="max-width:760px;margin:0 auto;">
            {page.features.map((f) => (
              <li>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#ebd200"/><path d="M7 12.4l3.2 3.1L17 8.7" stroke="#1a191d" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="final">
        <div class="wrap">
          <span class="eyebrow on-dark center">Start Your Project</span>
          <h2>Ready to Get Started?</h2>
          <div class="hero-cta-row">
            <a class="btn btn-primary btn-lg" href="/contact/">Get a Free Quote</a>
            <a class="btn btn-ghost btn-lg js-call" href={site.callHref}>Call {site.callPhone}</a>
          </div>
        </div>
      </section>
    </>
  )}
</Base>
