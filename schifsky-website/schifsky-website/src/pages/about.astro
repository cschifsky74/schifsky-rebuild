---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.js';

const title = 'About Schifsky Companies | Family-Owned Landscapers, Twin Cities';
const description =
  'Schifsky Companies is a family-owned landscape design & build contractor in Lake Elmo, MN, serving the Twin Cities for 37+ years. Meet the team and our 3D design process.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.name,
  url: site.domain,
  foundingDate: String(site.foundedYear),
  founder: { '@type': 'Person', name: 'Carson Schifsky' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.state,
    postalCode: site.address.zip,
    addressCountry: site.address.country,
  },
  telephone: site.phone,
};

const values = [
  { name: 'Leadership', text: 'We take responsibility for our actions, support one another, and lead by example every day.' },
  { name: 'Integrity', text: 'We do what we say we’re going to do — even when it’s harder, costs more, or no one is watching.' },
  { name: 'Fortitude', text: 'We face challenges head-on with resilience, discipline, and grit, and finish strong without cutting corners.' },
  { name: 'Excellence', text: 'We hold ourselves to a higher standard in how we think, communicate, and perform.' },
];

const team = [
  { name: 'Carson Schifsky', role: 'President', bio: 'Carson leads clients through the design-build process and drives the company forward with a focus on growth and innovation.' },
  { name: 'Gavin Albin', role: 'Vice President', bio: 'Gavin drives business growth by managing people and systems, with a focus on performance, goal-setting, and operational excellence.' },
  { name: 'Colton Schifsky', role: 'Excavation Project Manager', bio: 'Carson’s older brother, Colton has been part of the family business his whole life — project manager, estimator, and equipment operator.' },
  { name: 'Brandon Anderson', role: 'Landscape Project Manager', bio: 'Brandon keeps projects on track through meticulous planning, efficient scheduling, and clear communication.' },
];
---

<Base title={title} description={description} path="/about/" jsonLd={jsonLd}>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow on-dark">Our Story</span>
      <h1>A Family Business, Built on Doing It Right</h1>
      <p>Family-owned landscape design &amp; build, serving the Twin Cities for {site.yearsInBusiness}+ years.</p>
    </div>
  </section>

  <section>
    <div class="wrap split">
      <div class="split-img reveal">
        <img src="/img/placeholder-3.jpg" alt="Schifsky-built outdoor living space with paver patio in the Twin Cities" width="1100" height="733" />
        <div class="badge-float"><b>Since {site.foundedYear}</b><span>Family-Owned</span></div>
      </div>
      <div class="reveal prose" style="margin:0;">
        <p>
          Founded in {site.foundedYear} in Stillwater, MN, Schifsky Companies began with a focus on
          retaining walls and paver patios. Over {site.yearsInBusiness}+ years we&rsquo;ve grown and
          evolved — expanding into 3D landscape design, complete design-build services, and both
          residential and commercial excavation.
        </p>
        <p>
          As a proud family-owned business, we&rsquo;ve stayed committed to the same core values the
          whole way: leadership, integrity, fortitude, and excellence. Today, Schifsky Companies is a
          respected name across the Twin Cities, delivering projects that are built to last.
        </p>
      </div>
    </div>
  </section>

  <section class="process">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow center">What We Stand For</span>
        <h2>Our Core Values</h2>
      </div>
      <div class="values">
        {values.map((v) => (
          <div class="value reveal">
            <h3>{v.name}</h3>
            <p>{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="wrap split">
      <div class="reveal">
        <span class="eyebrow">How We Work</span>
        <h2>Design First, in 3D</h2>
        <p class="lead">
          We believe a project succeeds or fails in the design phase. Our designers create a tailored
          plan with realistic 3D renderings, so you can see and refine your outdoor space before any
          work begins — no guesswork. From there, one accountable team handles the build start to
          finish, keeping your project on schedule and clearly communicated.
        </p>
        <a class="btn btn-dark" href="/services/">Explore Our Services</a>
      </div>
      <div class="split-img reveal">
        <img src="/img/placeholder-6.jpg" alt="3D-designed backyard with pool, pergola and paver patio built by Schifsky Companies" width="1100" height="824" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="reviews">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow center">The Team</span>
        <h2>Meet the Leadership</h2>
      </div>
      <div class="team-grid">
        {team.map((m) => (
          <div class="member reveal">
            <div class="av" aria-hidden="true">{m.name.charAt(0)}</div>
            <h3>{m.name}</h3>
            <div class="role">{m.role}</div>
            <p>{m.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="final">
    <div class="wrap">
      <span class="eyebrow on-dark center">Work With Us</span>
      <h2>Let&rsquo;s Build Something That Lasts</h2>
      <div class="hero-cta-row">
        <a class="btn btn-primary btn-lg" href="/contact/">Get a Free Quote</a>
        <a class="btn btn-ghost btn-lg js-call" href={site.callHref}>Call {site.callPhone}</a>
      </div>
    </div>
  </section>
</Base>
